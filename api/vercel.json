{
    "version": 2,
    "builds": [
      { "src": "api/index.py", "use": "@vercel/python" },
      { "src": "vite.config.js", "use": "@vercel/static-build", "config": {} }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "/api/index.py" },
      { "src": "/(.*)", "dest": "/index.html" }
    ]
  }
  